rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'kvinit6421@gmail.com' && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Anime Rules
    match /anime/{animeId} {
      allow read: if true; // Public can see anime entries
      allow write: if isAdmin();
      
      // Allow incrementing clicks even for non-admins if we want to track it from client
      // However, usually better to track clicks via specific path or server proxy to avoid abuse
      // For this simple version, we'll allow partial update for clicks
      allow update: if (
        (isAdmin()) || 
        (incoming().diff(resource.data).affectedKeys().hasOnly(['clicks']) && incoming().clicks == resource.data.clicks + 1)
      );
    }

    // Banners Rules
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Stats Rules
    match /stats/{statId} {
      allow read: if isAdmin();
      allow create, update: if true; // Anyone can contribute to stats (or restricted by IP on server if needed)
    }
  }
}
