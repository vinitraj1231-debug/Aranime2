rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'kvinit6421@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // Admin List Rules
    match /admins/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Anime Rules
    match /anime/{animeId} {
      allow read: if true;
      allow write: if isAdmin();
      
      allow update: if (
        (isAdmin()) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']))
      );
    }

    // Banners Rules
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Stats Rules
    match /stats/{statId} {
      allow read: if isAdmin();
      allow create, update: if true; // Anyone can contribute to stats (or restricted by IP on server if needed)
    }
  }
}
