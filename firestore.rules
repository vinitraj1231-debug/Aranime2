rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'kvinit6421@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // Admin List Rules
    match /admins/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Anime Rules
    match /anime/{animeId} {
      allow read, write: if true;
    }

    // Banners Rules
    match /banners/{bannerId} {
      allow read, write: if true;
    }

    // Stats Rules
    match /stats/{statId} {
      allow read, write: if true;
    }

    // Config Rules
    match /config/{configId} {
      allow read, write: if true;
    }

    // User Profiles Rules
    match /user_profiles/{profileId} {
      allow read, write: if true;
    }

    // Connection Test Verification Rule
    match /test/{docId} {
      allow read: if true;
    }
  }
}
